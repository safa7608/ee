                    <button onclick="filterByCategory('engine')" class="category-btn px-4 py-2 bg-gear-gray text-gray-300 hover:text-white text-sm font-bold rounded-sm whitespace-nowrap transition-all border border-red-900/20" data-category="engine">ENGINE</button>
                    <button onclick="filterByCategory('brakes')" class="category-btn px-4 py-2 bg-gear-gray text-gray-300 hover:text-white text-sm font-bold rounded-sm whitespace-nowrap transition-all border border-red-900/20" data-category="brakes">BRAKES</button>
                    <button onclick="filterByCategory('suspension')" class="category-btn px-4 py-2 bg-gear-gray text-gray-300 hover:text-white text-sm font-bold rounded-sm whitespace-nowrap transition-all border border-red-900/20" data-category="suspension">SUSPENSION</button>
                    <button onclick="filterByCategory('electrical')" class="category-btn px-4 py-2 bg-gear-gray text-gray-300 hover:text-white text-sm font-bold rounded-sm whitespace-nowrap transition-all border border-red-900/20" data-category="electrical">ELECTRICAL</button>
                </div>
            </div>
