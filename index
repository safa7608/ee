                <a href="#deals" class="block px-3 py-2 text-gray-300 hover:text-gear-red hover:bg-gear-gray rounded-md">DEALS</a>
                <a href="#support" class="block px-3 py-2 text-gray-300 hover:text-gear-red hover:bg-gear-gray rounded-md">SUPPORT</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
