                        <p class="text-gear-red text-xs tracking-[0.3em] font-bold">MOTORS</p>
                    </div>
                </div>
                
                <div class="hidden md:flex items-center space-x-8">
                    <a href="#products" class="text-gray-300 hover:text-gear-red transition-colors font-medium tracking-wide">PARTS</a>
                    <a href="#categories" class="text-gray-300 hover:text-gear-red transition-colors font-medium tracking-wide">CATEGORIES</a>
                    <a href="#brands" class="text-gray-300 hover:text-gear-red transition-colors font-medium tracking-wide">BRANDS</a>
                    <a href="#deals" class="text-gray-300 hover:text-gear-red transition-colors font-medium tracking-wide">DEALS</a>
                    <a href="#support" class="text-gray-300 hover:text-gear-red transition-colors font-medium tracking-wide">SUPPORT</a>
