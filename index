            <i class="fas fa-chevron-down text-gear-red text-2xl"></i>
        </div>
    </section>

    <!-- Search & Filter Bar -->
    <section class="sticky top-20 z-40 bg-gear-dark/95 backdrop-blur-md border-y border-red-900/20 py-4">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <div class="relative w-full md:w-96">
                    <input type="text" id="search-input" placeholder="Search parts (e.g., brake pads, filters...)" 
