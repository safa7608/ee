            <div class="inline-block mb-6 px-4 py-2 border border-gear-red/50 rounded-full bg-gear-red/10 backdrop-blur-sm">
                <span class="text-gear-red font-bold tracking-widest text-sm scramble-text" data-text="PREMIUM AUTO PARTS">PREMIUM AUTO PARTS</span>
            </div>
            
            <h1 class="gear-text text-5xl md:text-7xl lg:text-8xl font-black mb-6 leading-tight">
                POWER YOUR <br>
