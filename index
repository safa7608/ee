                <div class="text-center">
                    <div class="text-4xl font-black text-gear-red gear-text">50K+</div>
                    <div class="text-gray-400 text-sm tracking-wider mt-1">PARTS IN STOCK</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-black text-gear-red gear-text">24H</div>
                    <div class="text-gray-400 text-sm tracking-wider mt-1">EXPRESS DELIVERY</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-black text-gear-red gear-text">100%</div>
                    <div class="text-gray-400 text-sm tracking-wider mt-1">OEM QUALITY</div>
                </div>
