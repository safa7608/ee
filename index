                </div>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-gear-dark border-t border-red-900/30">
            <div class="px-4 pt-2 pb-6 space-y-2">
